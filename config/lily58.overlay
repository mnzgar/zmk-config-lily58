/ {
    encoders {
        compatible = "zmk,encoders";

        left_encoder: encoder_left {
            a-gpios = <&pro_micro 2 GPIO_ACTIVE_LOW>;
            b-gpios = <&pro_micro 3 GPIO_ACTIVE_LOW>;
            steps = <4>;
        };

        right_encoder: encoder_right {
            a-gpios = <&pro_micro 4 GPIO_ACTIVE_LOW>;
            b-gpios = <&pro_micro 5 GPIO_ACTIVE_LOW>;
            steps = <4>;
        };
    };
};